{
    "name": "jasonej/laravel-endpoints",
    "description": "Single file endpoints for Laravel.",
    "keywords": ["laravel", "routing", "endpoints", "attributes"],
    "minimum-stability": "stable",
    "license": "MIT",
    "authors": [
        {
            "name": "Jason Jones",
            "email": "jason.erik.jones@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Jasonej\\LaravelEndpoints\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jasonej\\LaravelEndpoints\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3||^8.4||^8.5",
        "illuminate/contracts": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/validation": "^13.0",
        "spatie/php-attribute-reader": "^1.1",
        "spatie/php-structure-discoverer": "^2.4"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.5"
    },
    "scripts": {
        "check-code": [
            "@lint",
            "@stan",
            "@test"
        ],
        "lint": "@php vendor/bin/pint --test",
        "lint:fix": "@php vendor/bin/pint",
        "stan": "@php vendor/bin/phpstan analyse",
        "test": "@php vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jasonej\\LaravelEndpoints\\EndpointServiceProvider"
            ]
        }
    }
}
